# zshrc is only used by interactive shells, so it is safe to
# set environment variables here that shouldn't be used by
# non-interactive programs and applications.

# Disable flow control, so the terminal doesn't freeze
# when we press ctrl-s. Without it flow can be regained
# by pressing ctrl-q.
[[ -t 0 ]] && stty ixany

# Lines configured by zsh-newuser-install
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=$HISTSIZE
setopt hist_ignore_dups
bindkey -e
# End of lines configured by zsh-newuser-install

{{ if eq .chezmoi.os "darwin" -}}
HOMEBREW_PREFIX=${HOMEBREW_PREFIX:-$(brew --prefix)}
ZSH_PLUGIN_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/plugins"
FPATH="$HOMEBREW_PREFIX/share/zsh-completions:$FPATH"
source "$HOMEBREW_PREFIX/share/zsh-autocomplete/zsh-autocomplete.plugin.zsh"
{{ else if eq .chezmoi.os "linux" -}}
ZSH_PLUGIN_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/plugins"
FPATH="$ZSH_PLUGIN_DIR/zsh-completions/src:$FPATH"
source "$ZSH_PLUGIN_DIR/zsh-autocomplete/zsh-autocomplete.plugin.zsh"
{{ else -}}
autoload -Uz compinit
compinit
{{ end -}}

# The following lines were added by compinstall
zstyle :compinstall filename "$HOME/.zshrc"

ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets pattern cursor)

{{ if eq .chezmoi.os "darwin" -}}
source "$HOMEBREW_PREFIX/share/zsh-history-substring-search/zsh-history-substring-search.zsh"
source "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "$ZSH_PLUGIN_DIR/zsh-z/zsh-z.plugin.zsh"
{{ else if eq .chezmoi.os "linux" -}}
source "$ZSH_PLUGIN_DIR/zsh-history-substring-search/zsh-history-substring-search.zsh"
source "$ZSH_PLUGIN_DIR/zsh-z/zsh-z.plugin.zsh"
source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
{{ end -}}

### prefix history search
# Type the start of a command, then use up/down, pageup/pagedown, or ctrl-p/ctrl-n
# to cycle through only history entries with that prefix.
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
bindkey '^[[5~' history-substring-search-up
bindkey '^[[6~' history-substring-search-down
bindkey '^P' history-substring-search-up
bindkey '^N' history-substring-search-down

### bind Ctr-arrow keys for emacs-like word skip
bindkey -M emacs "^[[1;5C" forward-word
bindkey -M emacs "^[[1;5D" backward-word

### bind Ctrl-delete keys for emacs-like kill word
bindkey -M emacs '^[[3;5~' kill-word
bindkey -M emacs '^H' backward-kill-word

### starship
export STARSHIP_CONFIG="$HOME/.config/starship.toml"
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# pipx
autoload -Uz compinit
compinit
autoload -Uz bashcompinit
bashcompinit
if command -v register-python-argcomplete >/dev/null 2>&1; then
  eval "$(register-python-argcomplete pipx)"
fi

## direnv
if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

autoload -U +X bashcompinit && bashcompinit
if command -v terraform >/dev/null 2>&1; then
  complete -o nospace -C "$(command -v terraform)" terraform
fi

# The next line updates PATH for the Google Cloud SDK.
if [ -f "$HOME/Downloads/google-cloud-sdk/path.zsh.inc" ]; then . "$HOME/Downloads/google-cloud-sdk/path.zsh.inc"; fi

# The next line enables shell command completion for gcloud.
if [ -f "$HOME/Downloads/google-cloud-sdk/completion.zsh.inc" ]; then . "$HOME/Downloads/google-cloud-sdk/completion.zsh.inc"; fi

# open markdown files as html in chrome
render-markdown () {
  id=$(uuidgen | cut -c -8)
  today=$(date)
  filename=$1:t:r
  filepath=/tmp/md-$id.html
  html_body=$(
    pandoc \
    --standalone \
    --metadata date-meta=$today \
    --metadata date=$today \
    --metadata title=$filename \
    --template \
    "$HOME/.config/zsh/markdown-template.html" $1
  )
  (echo $html_body) > $filepath
  google-chrome $filepath
}

# necessary to use tramp-mode
[[ $TERM == "dumb" ]] && unsetopt zle && PS1='$ ' && return

# nvm
export NVM_DIR="$HOME/.nvm"

