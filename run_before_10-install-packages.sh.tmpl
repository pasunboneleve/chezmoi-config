#!/usr/bin/env bash
set -euo pipefail

if [ "${CHEZMOI_INSTALL_PACKAGES:-0}" != "1" ]; then
  echo "Skipping package installation. Set CHEZMOI_INSTALL_PACKAGES=1 to enable it."
  exit 0
fi

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/.bun/bin:$HOME/go/bin:$PATH"

skip_emacs_config="${CHEZMOI_SKIP_EMACS_CONFIG:-0}"

if [ -n "${NO_COLOR:-}" ]; then
  red=""
  yellow=""
  reset=""
else
  red=$'\033[31m'
  yellow=$'\033[33m'
  reset=$'\033[0m'
fi

colorize_errors() {
  awk -v red="$red" -v yellow="$yellow" -v reset="$reset" '
    /(^|[[:space:]])(Error:|error:|Failed|failed|No match|Problem:|Cannot|Memory exhausted|Killed|timeout:|chezmoi:)/ {
      print red $0 reset
      next
    }
    /(^|[[:space:]])(Warning:|warning:|WARNING:|warn:|Please note|quality may vary|not part of the main distribution)/ {
      print yellow $0 reset
      next
    }
    { print }
  '
}

run_with_colored_errors() {
  set +e
  "$@" </dev/null 2>&1 | colorize_errors
  local status="${PIPESTATUS[0]}"
  set -e
  return "$status"
}

ensure_emacs() {
  if command -v emacs >/dev/null 2>&1; then
    echo "Emacs is already installed."
    return
  fi

  if command -v dnf >/dev/null 2>&1; then
    echo "Installing Emacs with dnf."
    run_with_colored_errors sudo dnf install -y emacs
    return
  fi

  if command -v brew >/dev/null 2>&1; then
    echo "Installing Emacs with Homebrew."
    brew install emacs
    return
  fi

  echo "emacs is not installed, and neither dnf nor brew is available to install it."
  exit 1
}

ensure_emacs_config() {
  local config_dir="$HOME/.config/emacs"
  local current_branch
  local github_owner="pasunboneleve"
  local remote
  local remote_url
  local upstream

  if [ -d "$config_dir/.git" ]; then
    echo "Updating Emacs config in $config_dir."
    if ! git -C "$config_dir" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
      current_branch="$(git -C "$config_dir" branch --show-current)"
      if [ -z "$current_branch" ]; then
        echo "$config_dir is on a detached HEAD and cannot track a github.com/$github_owner main branch."
        exit 1
      fi

      for remote in origin pasunboneleve $(git -C "$config_dir" remote); do
        if [ -n "${upstream:-}" ]; then
          break
        fi

        if ! git -C "$config_dir" remote get-url "$remote" >/dev/null 2>&1; then
          continue
        fi

        remote_url="$(git -C "$config_dir" remote get-url "$remote")"
        case "$remote_url" in
          git@github.com:"$github_owner"/*|ssh://git@github.com/"$github_owner"/*|https://github.com/"$github_owner"/*) ;;
          *) continue ;;
        esac

        if git -C "$config_dir" fetch "$remote" "+refs/heads/main:refs/remotes/$remote/main"; then
          upstream="$remote/main"
        fi
      done

      if [ -z "${upstream:-}" ]; then
        echo "$config_dir has no github.com/$github_owner remote main branch to track."
        exit 1
      fi

      echo "Setting upstream for $current_branch to $upstream."
      git -C "$config_dir" branch --set-upstream-to="$upstream" "$current_branch"
    fi
    git -C "$config_dir" pull --ff-only
    return
  fi

  if [ -e "$config_dir" ]; then
    echo "$config_dir exists but is not a git checkout."
    exit 1
  fi

  mkdir -p "$(dirname "$config_dir")"
  echo "Cloning Emacs config into $config_dir."
  git clone git@github.com:pasunboneleve/emacs.d.git "$config_dir"
}

install_emacs_packages() {
  local config_dir="$HOME/.config/emacs"
  local elpaca_queue_limit="${CHEZMOI_ELPACA_QUEUE_LIMIT:-1}"
  local native_disabled="${CHEZMOI_EMACS_BATCH_NATIVE_DISABLED:-1}"
  # Bound the Emacs batch phase so an idle Elpaca wait fails instead of
  # leaving the whole chezmoi apply blocked indefinitely.
  local emacs_batch_timeout="${CHEZMOI_EMACS_BATCH_TIMEOUT:-30m}"
  local timeout_command
  local -a emacs_args

  if [ "$skip_emacs_config" = "1" ]; then
    echo "Skipping Emacs config setup because CHEZMOI_SKIP_EMACS_CONFIG=1."
    return
  fi

  ensure_emacs
  ensure_emacs_config

  if command -v timeout >/dev/null 2>&1; then
    timeout_command="timeout"
  elif command -v gtimeout >/dev/null 2>&1; then
    timeout_command="gtimeout"
  else
    echo "Emacs batch setup requires timeout or gtimeout."
    exit 1
  fi

  if [[ "$elpaca_queue_limit" == *[!0-9]* ]]; then
    echo "CHEZMOI_ELPACA_QUEUE_LIMIT must be a number."
    exit 1
  fi

  if [ "$native_disabled" != "0" ] && [ "$native_disabled" != "1" ]; then
    echo "CHEZMOI_EMACS_BATCH_NATIVE_DISABLED must be 0 or 1."
    exit 1
  fi

  if [[ ! "$emacs_batch_timeout" =~ ^[0-9]+[smhd]?$ ]]; then
    echo "CHEZMOI_EMACS_BATCH_TIMEOUT must be a timeout value such as 900, 15m, or 1h."
    exit 1
  fi

  emacs_args=(--batch)
  # Override user-emacs-directory: Emacs defaults to ~/.emacs.d when it exists,
  # even if ~/.config/emacs also exists. Set it explicitly so batch runs use the
  # correct directory regardless of ~/.emacs.d presence.
  emacs_args+=(--eval "(setq user-emacs-directory (expand-file-name \"~/.config/emacs/\"))")
  # Prevent EPA from popping up a buffer on GPG failure (no key available);
  # in non-interactive/daemon contexts this blocks indefinitely.
  emacs_args+=(--eval "(setq epa-popup-info-window nil)")
  emacs_args+=(--eval "(setq elpaca-queue-limit $elpaca_queue_limit)")

  if [ -f "$config_dir/early-init.el" ]; then
    emacs_args+=(--load "$config_dir/early-init.el")
  fi

  emacs_args+=(--load "$config_dir/init.el")
  emacs_args+=(--eval "(elpaca-update-menus)")
  emacs_args+=(--eval "(elpaca-wait)")

  echo "Running Emacs batch setup for Elpaca packages."
  echo "Running Elpaca with queue limit $elpaca_queue_limit."
  echo "Emacs batch setup timeout is $emacs_batch_timeout."
  if [ "$native_disabled" = "1" ]; then
    echo "Disabling native compilation during Emacs batch setup."
    (
      # The Emacs config reads this flag to skip native compilation and
      # per-package Elpaca waits during the bootstrap run.
      export NATIVE_DISABLED=1
      run_with_colored_errors "$timeout_command" --foreground "$emacs_batch_timeout" emacs "${emacs_args[@]}"
    )
  else
    run_with_colored_errors "$timeout_command" --foreground "$emacs_batch_timeout" emacs "${emacs_args[@]}"
  fi
  echo "Emacs batch setup completed."
}

# Use half the logical CPU cores for Elpaca parallelism on any platform.
# nproc is Linux/GNU; sysctl is macOS; falls back to 2 workers minimum.
: "${CHEZMOI_ELPACA_QUEUE_LIMIT:=$(( $(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4) / 2 ))}"

{{ if eq .chezmoi.os "linux" -}}
configure_xremap_permissions() {
  if ! getent group input >/dev/null 2>&1; then
    sudo groupadd --system input
  fi

  if ! id -nG "$USER" | tr ' ' '\n' | grep -qx input; then
    sudo gpasswd -a "$USER" input
    echo "Added $USER to the input group. Log out and back in before running xremap as a user service."
  fi

  echo uinput | sudo tee /etc/modules-load.d/uinput.conf >/dev/null
  printf '%s\n' 'KERNEL=="uinput", GROUP="input", TAG+="uaccess", MODE:="0660", OPTIONS+="static_node=uinput"' \
    | sudo tee /etc/udev/rules.d/99-input.rules >/dev/null
  sudo modprobe uinput
  sudo udevadm control --reload-rules
  sudo udevadm trigger
}

ensure_dnf_config_manager() {
  run_with_colored_errors sudo dnf install -y 'dnf-command(config-manager)'
}

ensure_google_chrome_dnf_repo() {
  local signing_key_fingerprint="7721f63bd38b4796"
  local signing_key_url="https://dl.google.com/linux/linux_signing_key.pub"

  run_with_colored_errors sudo dnf install -y fedora-workstation-repositories
  ensure_dnf_config_manager
  run_with_colored_errors sudo dnf config-manager setopt google-chrome.enabled=1
  if ! rpm -qa 'gpg-pubkey*' | grep -qi "$signing_key_fingerprint"; then
    run_with_colored_errors sudo rpm --import "$signing_key_url"
  fi
}

ensure_tailscale_dnf_repo() {
  local repo_url="https://pkgs.tailscale.com/stable/fedora/tailscale.repo"

  ensure_dnf_config_manager

  if LANG=C.UTF-8 dnf --version | grep -q '^dnf5 version'; then
    run_with_colored_errors sudo dnf config-manager addrepo --overwrite --from-repofile="$repo_url"
  else
    run_with_colored_errors sudo dnf config-manager --add-repo "$repo_url"
  fi
}

enable_tailscale_service() {
  if command -v systemctl >/dev/null 2>&1; then
    run_with_colored_errors sudo systemctl enable --now tailscaled
  fi
}

enable_docker_service() {
  if command -v systemctl >/dev/null 2>&1; then
    run_with_colored_errors sudo systemctl enable --now docker
  fi
}

install_bitwarden_desktop_rpm() {
  if command -v bitwarden >/dev/null 2>&1; then
    return
  fi

  run_with_colored_errors sudo dnf install -y \
    'https://vault.bitwarden.com/download/?app=desktop&platform=linux&variant=rpm'
}

if command -v dnf >/dev/null 2>&1; then
  sudo dnf -y copr enable scottames/ghostty
  sudo dnf -y copr enable blakegardner/xremap
  ensure_tailscale_dnf_repo
  ensure_google_chrome_dnf_repo

  run_with_colored_errors sudo dnf install -y \
    chezmoi \
    direnv \
    docker-cli \
    docker-compose \
    emacs \
    gh \
    git \
    git-filter-repo \
    golang \
    google-chrome-stable \
    gstreamer1-plugin-openh264 \
    ghostty \
    jira-cli \
    levien-inconsolata-fonts \
    mozilla-openh264 \
    moby-engine \
    openh264 \
    openssl-devel \
    pkgconf-pkg-config \
    remmina \
    restic \
    ripgrep \
    tailscale \
    unzip \
    xremap-gnome \
    zathura \
    zsh \
    zsh-autosuggestions \
    zsh-syntax-highlighting

  install_bitwarden_desktop_rpm
  enable_docker_service
  enable_tailscale_service
  configure_xremap_permissions
fi

if ! command -v starship >/dev/null 2>&1; then
  echo "starship is not available from the enabled Fedora repos; install it separately."
fi

install_emacs_packages
{{ else if eq .chezmoi.os "darwin" -}}
if command -v brew >/dev/null 2>&1; then
  export HOMEBREW_NO_INTERACTIVE=1
  # emacs-plus provides NS/Cocoa support required for GUI daemon+client workflow
  if brew list --formula emacs &>/dev/null 2>&1; then
    brew uninstall --ignore-dependencies emacs
  fi
  # { yes || true; } answers any formula y/n prompts (e.g. new Python version);
  # the || true prevents a SIGPIPE from yes breaking set -o pipefail.
  { yes || true; } | brew install \
    python-argcomplete \
    awscli \
    chezmoi \
    coreutils \
    direnv \
    docker \
    docker-compose \
    d12frosted/emacs-plus/emacs-plus@30 \
    gh \
    git \
    git-filter-repo \
    gnupg \
    pinentry-mac \
    go \
    openssl@3 \
    pkg-config \
    restic \
    ripgrep \
    starship \
    zsh-autocomplete \
    zsh-autosuggestions \
    zsh-completions \
    zathura \
    zsh-history-substring-search \
    zsh-syntax-highlighting
  brew install --cask \
    codex \
    font-inconsolata \
    google-chrome \
    ghostty \
    google-cloud-sdk \
    karabiner-elements \
    rectangle \
    stats \
    windows-app
fi

install_emacs_packages
{{ end -}}
