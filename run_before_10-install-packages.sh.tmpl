#!/usr/bin/env bash
set -euo pipefail

if [ "${CHEZMOI_INSTALL_PACKAGES:-0}" != "1" ]; then
  echo "Skipping package installation. Set CHEZMOI_INSTALL_PACKAGES=1 to enable it."
  exit 0
fi

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/.bun/bin:$HOME/go/bin:$PATH"

if [ -n "${NO_COLOR:-}" ]; then
  red=""
  yellow=""
  reset=""
else
  red=$'\033[31m'
  yellow=$'\033[33m'
  reset=$'\033[0m'
fi

colorize_errors() {
  awk -v red="$red" -v yellow="$yellow" -v reset="$reset" '
    /(^|[[:space:]])(Error:|error:|Failed|failed|No match|Problem:|Cannot|Memory exhausted|Killed|timeout:|chezmoi:)/ {
      print red $0 reset
      next
    }
    /(^|[[:space:]])(Warning:|warning:|WARNING:|warn:|Please note|quality may vary|not part of the main distribution)/ {
      print yellow $0 reset
      next
    }
    { print }
  '
}

run_with_colored_errors() {
  set +e
  "$@" 2>&1 | colorize_errors
  local status="${PIPESTATUS[0]}"
  set -e
  return "$status"
}

install_from_script() {
  local name="$1"
  local url="$2"
  local installer

  installer="$(mktemp)"
  curl -fsSL "$url" -o "$installer"
  echo "Installing $name from $url"
  bash "$installer"
  rm -f "$installer"
}

install_js_package() {
  local executable="$1"
  local package="$2"

  if command -v "$executable" >/dev/null 2>&1; then
    return
  fi

  if command -v bun >/dev/null 2>&1; then
    bun install -g "$package"
    return
  fi

  if [ "${CHEZMOI_USE_NPM_FOR_JS_PACKAGES:-0}" = "1" ] && command -v npm >/dev/null 2>&1; then
    npm install -g "$package"
    return
  fi

  echo "$package requires bun. Set CHEZMOI_USE_NPM_FOR_JS_PACKAGES=1 to allow npm instead."
  exit 1
}

ensure_gh_extension() {
  local extension="$1"
  local repository="$2"

  if gh extension list | awk '{ print $1 " " $2 }' | grep -qx "gh $extension"; then
    return
  fi

  gh extension install "$repository"
}

ensure_rust_toolchain() {
  if command -v rustup >/dev/null 2>&1; then
    rustup update
    return
  fi

  if command -v cargo >/dev/null 2>&1; then
    return
  fi

  local installer
  installer="$(mktemp)"
  curl -fsSL https://sh.rustup.rs -o "$installer"
  echo "Installing Rust with rustup"
  sh "$installer" -y --no-modify-path
  rm -f "$installer"
}

ensure_emacs() {
  if command -v emacs >/dev/null 2>&1; then
    echo "Emacs is already installed."
    return
  fi

  if command -v dnf >/dev/null 2>&1; then
    echo "Installing Emacs with dnf."
    run_with_colored_errors sudo dnf install -y emacs
    return
  fi

  if command -v brew >/dev/null 2>&1; then
    echo "Installing Emacs with Homebrew."
    brew install emacs
    return
  fi

  echo "emacs is not installed, and neither dnf nor brew is available to install it."
  exit 1
}

ensure_emacs_config() {
  local config_dir="$HOME/.config/emacs"

  if [ -d "$config_dir/.git" ]; then
    echo "Updating Emacs config in $config_dir."
    git -C "$config_dir" pull --ff-only
    return
  fi

  if [ -e "$config_dir" ]; then
    echo "$config_dir exists but is not a git checkout."
    exit 1
  fi

  mkdir -p "$(dirname "$config_dir")"
  echo "Cloning Emacs config into $config_dir."
  git clone git@github.com:pasunboneleve/emacs.d.git "$config_dir"
}

install_emacs_packages() {
  local config_dir="$HOME/.config/emacs"
  local elpaca_queue_limit="${CHEZMOI_ELPACA_QUEUE_LIMIT:-1}"
  local native_disabled="${CHEZMOI_EMACS_BATCH_NATIVE_DISABLED:-1}"
  local -a emacs_args

  ensure_emacs
  ensure_emacs_config

  if [[ "$elpaca_queue_limit" == *[!0-9]* ]]; then
    echo "CHEZMOI_ELPACA_QUEUE_LIMIT must be a number."
    exit 1
  fi

  if [ "$native_disabled" != "0" ] && [ "$native_disabled" != "1" ]; then
    echo "CHEZMOI_EMACS_BATCH_NATIVE_DISABLED must be 0 or 1."
    exit 1
  fi

  emacs_args=(--batch)
  emacs_args+=(--eval "(setq elpaca-queue-limit $elpaca_queue_limit)")

  if [ -f "$config_dir/early-init.el" ]; then
    emacs_args+=(--load "$config_dir/early-init.el")
  fi

  emacs_args+=(--load "$config_dir/init.el")
  emacs_args+=(--eval "(elpaca-update-menus)")
  emacs_args+=(--eval "(elpaca-wait)")

  echo "Running Emacs batch setup for Elpaca packages."
  echo "Running Elpaca with queue limit $elpaca_queue_limit."
  if [ "$native_disabled" = "1" ]; then
    echo "Disabling native compilation during Emacs batch setup."
    (
      export NATIVE_DISABLED=1
      run_with_colored_errors emacs "${emacs_args[@]}"
    )
  else
    run_with_colored_errors emacs "${emacs_args[@]}"
  fi
  echo "Emacs batch setup completed."
}

{{ if eq .chezmoi.os "linux" -}}
configure_xremap_permissions() {
  if ! getent group input >/dev/null 2>&1; then
    sudo groupadd --system input
  fi

  if ! id -nG "$USER" | tr ' ' '\n' | grep -qx input; then
    sudo gpasswd -a "$USER" input
    echo "Added $USER to the input group. Log out and back in before running xremap as a user service."
  fi

  echo uinput | sudo tee /etc/modules-load.d/uinput.conf >/dev/null
  printf '%s\n' 'KERNEL=="uinput", GROUP="input", TAG+="uaccess", MODE:="0660", OPTIONS+="static_node=uinput"' \
    | sudo tee /etc/udev/rules.d/99-input.rules >/dev/null
  sudo modprobe uinput
  sudo udevadm control --reload-rules
  sudo udevadm trigger
}

if command -v dnf >/dev/null 2>&1; then
  sudo dnf -y copr enable blakegardner/xremap

  run_with_colored_errors sudo dnf install -y \
    chezmoi \
    cargo \
    direnv \
    emacs \
    gh \
    git \
    git-filter-repo \
    golang \
    ghostty \
    levien-inconsolata-fonts \
    nodejs \
    npm \
    openssl-devel \
    pkgconf-pkg-config \
    python-uv \
    ripgrep \
    rust \
    unzip \
    xremap-gnome \
    zsh \
    zsh-autosuggestions \
    zsh-syntax-highlighting

  configure_xremap_permissions
fi

if ! command -v kata >/dev/null 2>&1; then
  go install go.kenn.io/kata/cmd/kata@latest
fi

ensure_gh_extension markdown-preview ssh://git@github.com/yusukebe/gh-markdown-preview.git

if ! command -v starship >/dev/null 2>&1; then
  echo "starship is not available from the enabled Fedora repos; install it separately."
fi

if ! command -v bun >/dev/null 2>&1; then
  install_from_script bun https://bun.com/install
fi

if ! command -v uv >/dev/null 2>&1; then
  install_from_script uv https://astral.sh/uv/install.sh
fi

if ! command -v roborev >/dev/null 2>&1; then
  install_from_script roborev https://roborev.io/install.sh
fi

if ! command -v bd >/dev/null 2>&1; then
  install_from_script beads https://raw.githubusercontent.com/gastownhall/beads/main/scripts/install.sh
fi

if ! command -v skilpel >/dev/null 2>&1; then
  go install github.com/pasunboneleve/skilpel/cmd/skilpel@latest
fi

if ! command -v rush >/dev/null 2>&1; then
  go install github.com/shenwei356/rush@latest
fi

ensure_rust_toolchain

if ! command -v rumdl >/dev/null 2>&1; then
  cargo install rumdl
fi

if ! command -v emacs-lsp-booster >/dev/null 2>&1; then
  cargo install emacs-lsp-booster
fi

if ! command -v typst >/dev/null 2>&1; then
  cargo install --locked typst-cli
fi

if ! command -v tinymist >/dev/null 2>&1; then
  cargo install --git ssh://git@github.com/Myriad-Dreamin/tinymist.git --locked tinymist-cli
fi

if ! command -v pyright-langserver >/dev/null 2>&1; then
  uv tool install pyright
fi

icon_font_dir="${XDG_DATA_HOME:-$HOME/.local/share}/fonts/all-the-icons"
mkdir -p "$icon_font_dir"
for font in \
  all-the-icons.ttf \
  file-icons.ttf \
  fontawesome.ttf \
  material-design-icons.ttf \
  octicons.ttf \
  weathericons.ttf; do
  if [ ! -f "$icon_font_dir/$font" ]; then
    curl -fsSL \
      "https://raw.githubusercontent.com/domtronn/all-the-icons.el/master/fonts/$font" \
      -o "$icon_font_dir/$font"
  fi
done
fc-cache -f "$icon_font_dir"

nerd_icon_font_dir="${XDG_DATA_HOME:-$HOME/.local/share}/fonts/nerd-icons"
mkdir -p "$nerd_icon_font_dir"
if [ ! -f "$nerd_icon_font_dir/NFM.ttf" ]; then
  curl -fsSL \
    "https://raw.githubusercontent.com/rainstormstudio/nerd-icons.el/main/fonts/NFM.ttf" \
    -o "$nerd_icon_font_dir/NFM.ttf"
fi
fc-cache -f "$nerd_icon_font_dir"

plugin_dir="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/plugins"
mkdir -p "$plugin_dir"

if [ ! -d "$plugin_dir/zsh-autocomplete/.git" ]; then
  git clone git@github.com:marlonrichert/zsh-autocomplete.git "$plugin_dir/zsh-autocomplete"
fi

if [ ! -d "$plugin_dir/zsh-completions/.git" ]; then
  git clone git@github.com:zsh-users/zsh-completions.git "$plugin_dir/zsh-completions"
fi

if [ ! -d "$plugin_dir/zsh-history-substring-search/.git" ]; then
  git clone git@github.com:zsh-users/zsh-history-substring-search.git "$plugin_dir/zsh-history-substring-search"
fi

if [ ! -d "$plugin_dir/zsh-z/.git" ]; then
  git clone git@github.com:agkozak/zsh-z.git "$plugin_dir/zsh-z"
fi

plugin_bin="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/bin"
mkdir -p "$plugin_bin"
for executable in "$plugin_dir"/*/* "$HOME/.local/share/zinit/plugins"/*/*; do
  [ -f "$executable" ] || continue
  [ -x "$executable" ] || continue
  case "$executable" in
    */zinit-annex-*/*|*/zdharma-continuum---zinit-annex-*/*) continue ;;
  esac
  name="$(basename "$executable")"
  case "$name" in
    .*|*.plugin.zsh|*.zsh|*.zwc|*.png|*.md|test-*|run-tests*) continue ;;
  esac
  ln -sfn "$executable" "$plugin_bin/$name"
done

install_emacs_packages
