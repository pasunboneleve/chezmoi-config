#!/usr/bin/env bash
set -euo pipefail

if [ "${CHEZMOI_INSTALL_PACKAGES:-0}" != "1" ]; then
  echo "Skipping package installation. Set CHEZMOI_INSTALL_PACKAGES=1 to enable it."
  exit 0
fi

export PATH="$HOME/.local/bin:$HOME/.bun/bin:$HOME/go/bin:$PATH"

install_from_script() {
  local name="$1"
  local url="$2"
  local installer

  installer="$(mktemp)"
  curl -fsSL "$url" -o "$installer"
  echo "Installing $name from $url"
  bash "$installer"
  rm -f "$installer"
}

install_js_package() {
  local executable="$1"
  local package="$2"

  if command -v "$executable" >/dev/null 2>&1; then
    return
  fi

  if command -v bun >/dev/null 2>&1; then
    bun install -g "$package"
    return
  fi

  if [ "${CHEZMOI_USE_NPM_FOR_JS_PACKAGES:-0}" = "1" ] && command -v npm >/dev/null 2>&1; then
    npm install -g "$package"
    return
  fi

  echo "$package requires bun. Set CHEZMOI_USE_NPM_FOR_JS_PACKAGES=1 to allow npm instead."
  exit 1
}

{{ if eq .chezmoi.os "linux" -}}
if command -v dnf >/dev/null 2>&1; then
  sudo dnf -y copr enable blakegardner/xremap

  sudo dnf install -y \
    chezmoi \
    cargo \
    direnv \
    emacs \
    git \
    git-filter-repo \
    golang \
    ghostty \
    levien-inconsolata-fonts \
    nodejs \
    npm \
    python-uv \
    ripgrep \
    rust \
    unzip \
    xremap-gnome \
    zsh \
    zsh-autosuggestions \
    zsh-syntax-highlighting

  if command -v udevadm >/dev/null 2>&1; then
    sudo udevadm control --reload-rules
    sudo udevadm trigger --name-match=/dev/uinput
  fi
fi

if ! command -v starship >/dev/null 2>&1; then
  echo "starship is not available from the enabled Fedora repos; install it separately."
fi

if ! command -v bun >/dev/null 2>&1; then
  install_from_script bun https://bun.com/install
fi

if ! command -v uv >/dev/null 2>&1; then
  install_from_script uv https://astral.sh/uv/install.sh
fi

if ! command -v roborev >/dev/null 2>&1; then
  install_from_script roborev https://roborev.io/install.sh
fi

if ! command -v bd >/dev/null 2>&1; then
  install_from_script beads https://raw.githubusercontent.com/gastownhall/beads/main/scripts/install.sh
fi

install_js_package agent-skills-eval agent-skills-eval

if ! command -v emacs-lsp-booster >/dev/null 2>&1; then
  cargo install emacs-lsp-booster
fi

if ! command -v pyright-langserver >/dev/null 2>&1; then
  uv tool install pyright
fi

icon_font_dir="${XDG_DATA_HOME:-$HOME/.local/share}/fonts/all-the-icons"
mkdir -p "$icon_font_dir"
for font in \
  all-the-icons.ttf \
  file-icons.ttf \
  fontawesome.ttf \
  material-design-icons.ttf \
  octicons.ttf \
  weathericons.ttf; do
  if [ ! -f "$icon_font_dir/$font" ]; then
    curl -fsSL \
      "https://raw.githubusercontent.com/domtronn/all-the-icons.el/master/fonts/$font" \
      -o "$icon_font_dir/$font"
  fi
done
fc-cache -f "$icon_font_dir"

nerd_icon_font_dir="${XDG_DATA_HOME:-$HOME/.local/share}/fonts/nerd-icons"
mkdir -p "$nerd_icon_font_dir"
if [ ! -f "$nerd_icon_font_dir/NFM.ttf" ]; then
  curl -fsSL \
    "https://raw.githubusercontent.com/rainstormstudio/nerd-icons.el/main/fonts/NFM.ttf" \
    -o "$nerd_icon_font_dir/NFM.ttf"
fi
fc-cache -f "$nerd_icon_font_dir"

plugin_dir="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/plugins"
mkdir -p "$plugin_dir"

if [ ! -d "$plugin_dir/zsh-autocomplete/.git" ]; then
  git clone https://github.com/marlonrichert/zsh-autocomplete.git "$plugin_dir/zsh-autocomplete"
fi

if [ ! -d "$plugin_dir/zsh-completions/.git" ]; then
  git clone https://github.com/zsh-users/zsh-completions.git "$plugin_dir/zsh-completions"
fi

if [ ! -d "$plugin_dir/zsh-history-substring-search/.git" ]; then
  git clone https://github.com/zsh-users/zsh-history-substring-search.git "$plugin_dir/zsh-history-substring-search"
fi

if [ ! -d "$plugin_dir/zsh-z/.git" ]; then
  git clone https://github.com/agkozak/zsh-z.git "$plugin_dir/zsh-z"
fi

plugin_bin="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/bin"
mkdir -p "$plugin_bin"
for executable in "$plugin_dir"/*/* "$HOME/.local/share/zinit/plugins"/*/*; do
  [ -f "$executable" ] || continue
  [ -x "$executable" ] || continue
  case "$executable" in
    */zinit-annex-*/*|*/zdharma-continuum---zinit-annex-*/*) continue ;;
  esac
  name="$(basename "$executable")"
  case "$name" in
    .*|*.plugin.zsh|*.zsh|*.zwc|*.png|*.md|test-*|run-tests*) continue ;;
  esac
  ln -sfn "$executable" "$plugin_bin/$name"
done
{{ else if eq .chezmoi.os "darwin" -}}
if command -v brew >/dev/null 2>&1; then
  brew install \
    chezmoi \
    direnv \
    emacs \
    git \
    git-filter-repo \
    go \
    node \
    ripgrep \
    roborev-dev/tap/roborev \
    rust \
    starship \
    uv \
    beads \
    bun \
    zsh \
    zsh-autocomplete \
    zsh-autosuggestions \
    zsh-completions \
    zsh-history-substring-search \
    zsh-syntax-highlighting
  brew install --cask \
    font-inconsolata \
    ghostty
fi

if ! command -v bun >/dev/null 2>&1; then
  install_from_script bun https://bun.com/install
fi

if ! command -v uv >/dev/null 2>&1; then
  install_from_script uv https://astral.sh/uv/install.sh
fi

if ! command -v roborev >/dev/null 2>&1; then
  install_from_script roborev https://roborev.io/install.sh
fi

if ! command -v bd >/dev/null 2>&1; then
  install_from_script beads https://raw.githubusercontent.com/gastownhall/beads/main/scripts/install.sh
fi

install_js_package agent-skills-eval agent-skills-eval

if ! command -v emacs-lsp-booster >/dev/null 2>&1; then
  cargo install emacs-lsp-booster
fi

if ! command -v pyright-langserver >/dev/null 2>&1; then
  uv tool install pyright
fi

icon_font_dir="$HOME/Library/Fonts/all-the-icons"
mkdir -p "$icon_font_dir"
for font in \
  all-the-icons.ttf \
  file-icons.ttf \
  fontawesome.ttf \
  material-design-icons.ttf \
  octicons.ttf \
  weathericons.ttf; do
  if [ ! -f "$icon_font_dir/$font" ]; then
    curl -fsSL \
      "https://raw.githubusercontent.com/domtronn/all-the-icons.el/master/fonts/$font" \
      -o "$icon_font_dir/$font"
  fi
done

nerd_icon_font_dir="$HOME/Library/Fonts/nerd-icons"
mkdir -p "$nerd_icon_font_dir"
if [ ! -f "$nerd_icon_font_dir/NFM.ttf" ]; then
  curl -fsSL \
    "https://raw.githubusercontent.com/rainstormstudio/nerd-icons.el/main/fonts/NFM.ttf" \
    -o "$nerd_icon_font_dir/NFM.ttf"
fi

plugin_dir="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/plugins"
mkdir -p "$plugin_dir"

if [ ! -d "$plugin_dir/zsh-z/.git" ]; then
  git clone https://github.com/agkozak/zsh-z.git "$plugin_dir/zsh-z"
fi

plugin_bin="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/bin"
mkdir -p "$plugin_bin"
for executable in "$plugin_dir"/*/*; do
  [ -f "$executable" ] || continue
  [ -x "$executable" ] || continue
  name="$(basename "$executable")"
  case "$name" in
    .*|*.plugin.zsh|*.zsh|*.zwc|*.png|*.md|test-*|run-tests*) continue ;;
  esac
  ln -sfn "$executable" "$plugin_bin/$name"
done
{{ end -}}
