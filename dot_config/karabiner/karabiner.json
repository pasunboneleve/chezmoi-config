          {
            "description": "Left GUI (thumb cluster Super) held alone → Mission Control; tap or hold+key → Cmd",
            "manipulators": [
              {
                "type": "basic",
                "from": { "key_code": "left_command", "modifiers": { "optional": ["any"] } },
                "to": [{ "key_code": "left_command" }],
                "to_if_held_down": [{ "apple_vendor_keyboard_key_code": "mission_control" }],
                "parameters": {
                  "basic.to_if_held_down_threshold_milliseconds": 300
                }
              }
            ]
          },
          {
            "description": "Emacs C-x prefix: activate C-x mode (not in Emacs/terminals)",
            "manipulators": [
              {
                "type": "basic",
                "conditions": [
                  { "type": "variable_unless", "name": "ctrl_x_mode", "value": 1 },
                  { "type": "frontmost_application_unless", "bundle_identifiers": [
                    "^org\\.gnu\\.Emacs",
                    "^com\\.mitchellh\\.ghostty",
                    "^com\\.apple\\.Terminal",
                    "^com\\.googlecode\\.iterm2",
                    "^io\\.alacritty",
                    "^net\\.kovidgoyal\\.kitty"
                  ]}
                ],
                "from": { "key_code": "x", "modifiers": { "mandatory": ["control"], "optional": ["any"] } },
                "to": [{ "set_variable": { "name": "ctrl_x_mode", "value": 1 } }],
                "to_delayed_action": {
                  "to_if_invoked": [
                    { "set_variable": { "name": "ctrl_x_mode", "value": 0 } }
                  ],
                  "to_if_canceled": [
                    { "set_variable": { "name": "ctrl_x_mode", "value": 0 } }
                  ]
                },
                "parameters": {
                  "basic.to_delayed_action_delay_milliseconds": 1000
                }
              }
            ]
