#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/.bun/bin:$HOME/go/bin:$PATH"

install_from_script() {
  local name="$1"
  local url="$2"
  local installer

  installer="$(mktemp)"
  curl -fsSL "$url" -o "$installer"
  echo "Installing $name from $url"
  bash "$installer"
  rm -f "$installer"
}

ensure_nvm() {
  export NVM_DIR="$HOME/.nvm"

  if [ ! -s "$NVM_DIR/nvm.sh" ]; then
    echo "Installing nvm."
    PROFILE=/dev/null bash -c \
      "$(curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh)"
  fi

  # shellcheck disable=SC1091
  . "$NVM_DIR/nvm.sh"
}

ensure_node() {
  ensure_nvm
  nvm install --lts
  nvm alias default 'lts/*'
}

ensure_rust_toolchain() {
  export PATH="$HOME/.cargo/bin:$PATH"

  if command -v rustup >/dev/null 2>&1; then
    rustup update
    return
  fi

  local installer
  installer="$(mktemp)"
  curl -fsSL https://sh.rustup.rs -o "$installer"
  echo "Installing Rust with rustup"
  sh "$installer" -y --no-modify-path
  rm -f "$installer"

  # shellcheck disable=SC1091
  . "$HOME/.cargo/env"
}

install_bun_tool() {
  local executable="$1"
  local package="$2"

  if command -v "$executable" >/dev/null 2>&1; then
    return
  fi

  bun add -g "$package"
}

install_claude_cli() {
  if command -v claude >/dev/null 2>&1; then
    return
  fi

  curl -fsSL https://claude.ai/install.sh | bash
}

latest_github_tag() {
  local repository="$1"
  local tag

  tag="$(
    curl -fsSL "https://api.github.com/repos/$repository/releases/latest" \
      | sed -n 's/^[[:space:]]*"tag_name":[[:space:]]*"\([^"]*\)".*/\1/p' \
      | head -n 1
  )"

  if [ -z "$tag" ]; then
    echo "Could not determine latest release tag for $repository." >&2
    exit 1
  fi

  printf '%s\n' "$tag"
}

github_latest_download_url() {
  local repository="$1"
  local asset="$2"

  printf 'https://github.com/%s/releases/latest/download/%s\n' "$repository" "$asset"
}

github_tag_download_url() {
  local repository="$1"
  local tag="$2"
  local asset="$3"

  printf 'https://github.com/%s/releases/download/%s/%s\n' "$repository" "$tag" "$asset"
}

install_github_binary_asset() {
  local executable="$1"
  local repository="$2"
  local asset="$3"
  local url

  if command -v "$executable" >/dev/null 2>&1; then
    return
  fi

  url="$(github_latest_download_url "$repository" "$asset")"
  echo "Installing $executable from $url"
  mkdir -p "$HOME/.local/bin"
  curl -fL "$url" -o "$HOME/.local/bin/$executable"
  chmod 0755 "$HOME/.local/bin/$executable"
}

install_github_archive_binary_url() {
  local executable="$1"
  local url="$2"
  local archive
  local binary
  local tmpdir

  if command -v "$executable" >/dev/null 2>&1; then
    return
  fi

  tmpdir="$(mktemp -d)"
  archive="$tmpdir/asset"

  echo "Installing $executable from $url"
  curl -fL "$url" -o "$archive"
  tar -xf "$archive" -C "$tmpdir"

  binary=""
  while IFS= read -r candidate; do
    if [ -x "$candidate" ]; then
      binary="$candidate"
      break
    fi
  done < <(find "$tmpdir" -type f -name "$executable")

  if [ -z "$binary" ]; then
    echo "Could not find $executable in $url." >&2
    rm -rf "$tmpdir"
    exit 1
  fi

  mkdir -p "$HOME/.local/bin"
  install -m 0755 "$binary" "$HOME/.local/bin/$executable"
  rm -rf "$tmpdir"
}

install_github_archive_binary_asset() {
  local executable="$1"
  local repository="$2"
  local asset="$3"
  local url

  url="$(github_latest_download_url "$repository" "$asset")"
  install_github_archive_binary_url "$executable" "$url"
}

install_cargo_tool() {
  local executable="$1"
  shift

  if command -v "$executable" >/dev/null 2>&1; then
    return
  fi

  cargo install "$@"
}

install_zellij() {
  case "$(uname -s):$(uname -m)" in
    Linux:x86_64)
      install_github_archive_binary_asset \
        zellij \
        zellij-org/zellij \
        zellij-x86_64-unknown-linux-musl.tar.gz
      ;;
    Linux:aarch64|Linux:arm64)
      install_github_archive_binary_asset \
        zellij \
        zellij-org/zellij \
        zellij-aarch64-unknown-linux-musl.tar.gz
      ;;
    Darwin:arm64|Darwin:aarch64)
      install_github_archive_binary_asset \
        zellij \
        zellij-org/zellij \
        zellij-aarch64-apple-darwin.tar.gz
      ;;
    Darwin:x86_64)
      install_github_archive_binary_asset \
        zellij \
        zellij-org/zellij \
        zellij-x86_64-apple-darwin.tar.gz
      ;;
    *)
      echo "Skipping zellij: unsupported platform $(uname -s):$(uname -m)."
      ;;
  esac
}

install_go_tool() {
  local executable="$1"
  local package="$2"

  if command -v "$executable" >/dev/null 2>&1; then
    return
  fi

  if ! command -v go >/dev/null 2>&1; then
    echo "$executable requires go. Run CHEZMOI_INSTALL_PACKAGES=1 chezmoi apply to install system packages first." >&2
    exit 1
  fi

  go install "$package"
}

