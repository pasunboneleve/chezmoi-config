install_icon_fonts() {
  {{ if eq .chezmoi.os "darwin" -}}
  local all_the_icons_dir="$HOME/Library/Fonts/all-the-icons"
  local nerd_icons_dir="$HOME/Library/Fonts/nerd-icons"
  {{ else -}}
  local all_the_icons_dir="${XDG_DATA_HOME:-$HOME/.local/share}/fonts/all-the-icons"
  local nerd_icons_dir="${XDG_DATA_HOME:-$HOME/.local/share}/fonts/nerd-icons"
  {{ end -}}

  mkdir -p "$all_the_icons_dir"
  for font in \
    all-the-icons.ttf \
    file-icons.ttf \
    fontawesome.ttf \
    material-design-icons.ttf \
    octicons.ttf \
    weathericons.ttf; do
    if [ ! -f "$all_the_icons_dir/$font" ]; then
      curl -fsSL \
        "https://raw.githubusercontent.com/domtronn/all-the-icons.el/master/fonts/$font" \
        -o "$all_the_icons_dir/$font"
    fi
  done

  mkdir -p "$nerd_icons_dir"
  if [ ! -f "$nerd_icons_dir/NFM.ttf" ]; then
    curl -fsSL \
      "https://raw.githubusercontent.com/rainstormstudio/nerd-icons.el/main/fonts/NFM.ttf" \
      -o "$nerd_icons_dir/NFM.ttf"
  fi

  {{ if eq .chezmoi.os "linux" -}}
  if command -v fc-cache >/dev/null 2>&1; then
    fc-cache -f "$all_the_icons_dir"
    fc-cache -f "$nerd_icons_dir"
  fi
  {{ end -}}
}

install_zsh_plugins() {
  if ! command -v git >/dev/null 2>&1; then
    echo "Skipping zsh plugin checkout: git is not installed."
    return
  fi

  local plugin_dir="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/plugins"
  local plugin_bin="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/bin"
  local executable
  local name

  mkdir -p "$plugin_dir"

  {{ if eq .chezmoi.os "linux" -}}
  if [ ! -d "$plugin_dir/zsh-autocomplete/.git" ]; then
    git clone git@github.com:marlonrichert/zsh-autocomplete.git "$plugin_dir/zsh-autocomplete"
  fi

  if [ ! -d "$plugin_dir/zsh-completions/.git" ]; then
    git clone git@github.com:zsh-users/zsh-completions.git "$plugin_dir/zsh-completions"
  fi

  if [ ! -d "$plugin_dir/zsh-history-substring-search/.git" ]; then
    git clone git@github.com:zsh-users/zsh-history-substring-search.git "$plugin_dir/zsh-history-substring-search"
  fi
  {{ end -}}

  if [ ! -d "$plugin_dir/zsh-z/.git" ]; then
    git clone git@github.com:agkozak/zsh-z.git "$plugin_dir/zsh-z"
  fi

  mkdir -p "$plugin_bin"
  {{ if eq .chezmoi.os "linux" -}}
  for executable in "$plugin_dir"/*/* "$HOME/.local/share/zinit/plugins"/*/*; do
  {{ else -}}
  for executable in "$plugin_dir"/*/*; do
  {{ end -}}
    [ -f "$executable" ] || continue
    [ -x "$executable" ] || continue
    case "$executable" in
      */zinit-annex-*/*|*/zdharma-continuum---zinit-annex-*/*) continue ;;
    esac
    name="$(basename "$executable")"
    case "$name" in
      .*|*.plugin.zsh|*.zsh|*.zwc|*.png|*.md|test-*|run-tests*) continue ;;
    esac
    ln -sfn "$executable" "$plugin_bin/$name"
  done
}

ensure_gh_extension() {
  local extension="$1"
  local repository="$2"

  if ! command -v gh >/dev/null 2>&1; then
    echo "Skipping gh $extension: gh is not installed."
    return
  fi

  if gh extension list | awk '{ print $1 " " $2 }' | grep -qx "gh $extension"; then
    return
  fi

  gh extension install "$repository"
}

